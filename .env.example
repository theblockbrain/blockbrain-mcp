# ============================================================================
# blockbrain-mcp — example environment configuration
# Copy to `.env` and fill in your own values.
# ============================================================================

# ─── Identity Provider ──────────────────────────────────────────────────────
# Pick ONE of the three paths below. See docs/PROVIDERS.md for per-provider
# walk-throughs (Entra ID, Zitadel, Auth0, Okta, Keycloak).

# --- A. Entra ID (Azure AD) — Single-Tenant [RECOMMENDED DEFAULT] -----------
# Get the Directory (tenant) ID from Azure Portal → App registration → Overview
AZURE_TENANT_ID=

# --- B. Entra ID — Multi-Tenant with explicit allow-list --------------------
# Leave AZURE_TENANT_ID empty and instead set:
#   AZURE_TENANT_ID=common
#   AZURE_ALLOWED_TENANTS=<tenant-a-uuid>,<tenant-b-uuid>
AZURE_ALLOWED_TENANTS=

# --- C. Any other OIDC provider (Zitadel, Auth0, Okta, Keycloak, ...) -------
# Leave AZURE_TENANT_ID empty, set:
#   OIDC_ISSUER_URL=https://auth.example.com
# Optional (derived from the issuer when omitted):
#   OIDC_JWKS_URI=https://auth.example.com/.well-known/jwks.json
OIDC_ISSUER_URL=
OIDC_JWKS_URI=

# ─── Resource Server Identity ───────────────────────────────────────────────
# Must match the `aud` claim issued to this server.
#   Entra:         the Application ID URI you set under "Expose an API"
#                  e.g. api://blockbrain-mcp
#   Others:        an absolute URL identifying this server
#                  e.g. https://mcp.example.com
MCP_RESOURCE_IDENTIFIER=

# Comma-separated required scopes. Example for Entra: mcp.access
MCP_REQUIRED_SCOPES=

# ─── Server ─────────────────────────────────────────────────────────────────
MCP_SERVER_NAME=Blockbrain MCP Template
MCP_HOST=0.0.0.0
MCP_PORT=8080
MCP_LOG_LEVEL=INFO

# Public URL Blockbrain uses to reach this server.
#   • `make serve` sets this automatically to the cloudflared tunnel URL.
#   • When running `make dev` alone (no tunnel), set this manually for prod or
#     to override the local URL.
#   • Required when MCP_RESOURCE_IDENTIFIER is not an http(s) URL.
MCP_PUBLIC_BASE_URL=

# ─── Tool-specific (⭐ CUSTOMIZE HERE — one block per tool) ─────────────────
# Brave Search API key — https://brave.com/search/api/ (2000 req/month free)
BRAVE_API_KEY=

# research_topic: daily per-user cap
RATE_LIMIT_RESEARCH_PER_DAY=50
